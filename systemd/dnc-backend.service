[Unit]
Description=DNC - backend Flask (USB + carpeta + transferencia serial)
After=network.target local-fs.target

[Service]
Type=simple
User=eduardo
Group=eduardo
WorkingDirectory=/home/eduardo/ZeuzDNC
ExecStart=/usr/bin/python3 /home/eduardo/ZeuzDNC/app.py
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
